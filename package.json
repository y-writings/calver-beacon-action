{
  "name": "calver-beacon-action",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable GitHub Action for creating CalVer release-trigger tags.",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true});\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "pnpm run clean && ncc build src/index.ts -o dist --target es2024",
    "ci": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "keywords": [
    "github-actions",
    "git-tag",
    "calver"
  ],
  "author": "Yoshiro M",
  "license": "MIT",
  "files": [
    "action.yml",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
